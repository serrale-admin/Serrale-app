# Local Expo web (CORS): point at a local backend
EXPO_PUBLIC_API_BASE_URL=http://127.0.0.1:5000/api
EXPO_PUBLIC_USE_MOCK=false

# Production / EAS profiles must use:
# EXPO_PUBLIC_API_BASE_URL=https://api.serrale.com/api
# EXPO_PUBLIC_USE_MOCK=false
# (eas.json production + preview env already set these — do not rely on this file for store builds)
